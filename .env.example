# Template config — aman di-commit. Copy ke .env, isi nilai asli.
# JANGAN PERNAH commit file .env asli yang berisi PRIVATE_KEY.

# === WAJIB ===

# Private key wallet mining (64 hex chars, prefix 0x optional).
# WAJIB pakai wallet baru khusus mining, bukan wallet utama.
# Top up minimal 0.05 ETH untuk gas.
PRIVATE_KEY=0xYOUR_64_HEX_PRIVATE_KEY_HERE

# === RPC ENDPOINT ===

# Default eth.llamarpc.com (publik, bisa rate-limit).
# Rekomendasi: pakai punya sendiri.
#   - Alchemy:    https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
#   - Infura:     https://mainnet.infura.io/v3/YOUR_KEY
#   - MEV Blocker (anti front-running): https://rpc.mevblocker.io/fast
RPC_URL=https://rpc.mevblocker.io/fast

# === GPU MULTI-DEVICE ===

# Set 1 untuk aktifin GPU OpenCL multi-device backend.
# Default: tidak set (= CPU-only). Set GPU=1 untuk GPU.
GPU=1

# Nonces per dispatch PER GPU. Default 16M = saturasi RTX 30/40-series.
#   - GPU util < 90% di nvidia-smi → naikin 33554432 (32M) atau 67108864 (64M)
#   - Out-of-memory error          → turunin 8388608 (8M) atau 4194304 (4M)
GPU_BATCH=16777216

# === CPU FALLBACK ===

# Banyak CPU thread kalau GPU gagal init / GPU=0.
# Default = jumlah core CPU. Override misal kalau VPS punya banyak vCPU.
MINER_THREADS=16

# === GAS (EIP-1559) ===

# Tip ke validator — naikin biar tx-mu prioritas masuk block lebih cepat.
#   - Mainnet sepi (base ≤ 5 gwei): 3
#   - Mainnet normal (5-15 gwei):   5-7
#   - Mainnet busy (>20 gwei):      10-15
PRIORITY_GWEI=5

# Ceiling absolute fee (max yang bersedia kamu bayar).
# Effective fee = min(MAX_FEE, baseFee + PRIORITY).
MAX_FEE_GWEI=80

# Optional: override gas limit (default = auto-estimate × 1.5)
# GAS_LIMIT_OVERRIDE=300000
